{
  "name": "demondash",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "localstack:up": "docker compose up -d",
    "localstack:down": "docker compose down",
    "localstack:logs": "docker compose logs -f localstack",
    "tf:init": "terraform -chdir=terraform init",
    "tf:validate": "terraform -chdir=terraform validate",
    "tf:plan": "terraform -chdir=terraform plan",
    "tf:apply": "terraform -chdir=terraform apply",
    "tf:destroy": "terraform -chdir=terraform destroy",
    "aws:verify": "bash ./scripts/aws-verify.sh",
    "stack:up": "bash ./scripts/stack-up.sh",
    "stack:down": "bash ./scripts/stack-down.sh",
    "stack:destroy": "bash ./scripts/stack-down.sh --destroy"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.716.0",
    "@aws-sdk/client-s3": "^3.716.0",
    "@aws-sdk/lib-dynamodb": "^3.716.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
