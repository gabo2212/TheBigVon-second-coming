# LocalStack's current unified image requires auth, so this project pins to
# the archived community image for local-only development.
# If you want newer Pro features instead, switch the image and provide a token.
LOCALSTACK_IMAGE=localstack/localstack:community-archive
ACTIVATE_PRO=0
LOCALSTACK_AUTH_TOKEN=

# Fake AWS credentials for LocalStack only. Do not point these clients at real AWS.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
LOCALSTACK_ENDPOINT=http://localhost:4566

# DemonDash resources created by Terraform in LocalStack.
DEMONDASH_EXPORTS_BUCKET=demondash-dev-exports
DEMONDASH_PROJECTS_TABLE=demondash-dev-projects
DEMONDASH_SAFETY_EVENTS_TABLE=demondash-dev-safety-events
